{
  "agent_name": "Bountive Operator",
  "description": "Autonomous GitHub-first task bounty operator for safe, budget-aware software missions.",
  "operator_wallet": "0x0000000000000000000000000000000000000000",
  "network": "base-sepolia",
  "identity_reference": "bountive-operator-dev",
  "registration_tx_hash": null,
  "manifest_uri": "artifacts/generated/agent.json",
  "supported_tools": [
    "github",
    "git",
    "npm",
    "pnpm",
    "yarn",
    "prisma",
    "sqlite",
    "postgresql",
    "redis"
  ],
  "supported_task_categories": [
    "configuration",
    "developer-experience copy",
    "documentation"
  ],
  "compute_budget": {
    "max_model_calls": 20,
    "max_tool_calls": 40,
    "max_retries": 2,
    "max_changed_files": 8
  },
  "guardrails": {
    "default_mode": "dry_run",
    "live_submission": false,
    "destructive_shell_commands_blocked": true,
    "allowlisted_live_repos_only": true,
    "approval_requires_passing_checks": true
  },
  "execution_modes": [
    "dry_run",
    "live"
  ],
  "proof_format_version": "bountive-proof/v1",
  "version": "0.1.0"
}
